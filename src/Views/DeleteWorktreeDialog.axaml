<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Fido.ViewModels"
        x:Class="Fido.Views.DeleteWorktreeDialog"
        x:DataType="vm:DeleteWorktreeDialogViewModel"
        Title="Delete worktree"
        SizeToContent="Height" Width="580"
        MinWidth="480" MaxWidth="780"
        CanResize="False"
        WindowDecorations="Full"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/fido-icon-256.png"
        FontFamily="{DynamicResource FidoMono}"
        Background="{DynamicResource FidoWindowBg}">

    <StackPanel Margin="22,20" Spacing="14">

        <TextBlock Text="Delete this worktree, its local branch, and the branch on origin?"
                   FontFamily="{DynamicResource FidoMono}" FontSize="15" FontWeight="SemiBold"
                   TextWrapping="Wrap" Foreground="{DynamicResource FidoTextPrimary}" />

        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto"
              ColumnSpacing="14" RowSpacing="5">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Worktree" Foreground="{DynamicResource FidoTextMuted}" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding WorktreePath}" TextWrapping="Wrap"
                       Foreground="{DynamicResource FidoTextBody}" FontSize="12.5" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Local branch" Foreground="{DynamicResource FidoTextMuted}" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Branch}" FontWeight="SemiBold"
                       Foreground="{DynamicResource FidoAccentText}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="On origin" Foreground="{DynamicResource FidoTextMuted}" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RemoteText}" TextWrapping="Wrap"
                       Foreground="{DynamicResource FidoTextBody}" />
        </Grid>

        <TextBlock Text="{Binding OrphanedSummary}" IsVisible="{Binding HasOrphanedCommits}"
                   TextWrapping="Wrap" Foreground="{DynamicResource FidoNoGoText}" />

        <TextBlock Text="{Binding OutstandingSummary}" IsVisible="{Binding HasOutstandingChanges}"
                   TextWrapping="Wrap" Foreground="{DynamicResource FidoNoGoText}" />

        <TextBlock Text="This can't be undone." TextWrapping="Wrap"
                   Foreground="{DynamicResource FidoNoGoText}" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,4,0,0">
            <Button x:Name="DeleteButton" Classes="danger" Content="Delete" Click="OnDeleteClick"
                    FontSize="13" Padding="24,9" />
            <Button x:Name="CancelButton" Classes="secondary" Content="Cancel" Click="OnCancelClick"
                    IsCancel="True" IsDefault="True" />
        </StackPanel>

        <TextBlock Text="Shortcuts: Enter / Esc = cancel · click Delete to confirm"
                   Foreground="{DynamicResource FidoTextDim}" FontSize="11" TextWrapping="Wrap" />

    </StackPanel>
</Window>
