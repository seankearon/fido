<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Fido.ViewModels"
        x:Class="Fido.Views.SettingsDialog"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        Width="480" SizeToContent="Height"
        MinWidth="420" CanResize="False"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/fido-icon-256.png"
        FontFamily="{DynamicResource FidoMono}"
        Background="{DynamicResource FidoWindowBg}">

    <StackPanel Margin="22,20" Spacing="18">

        <StackPanel Spacing="9">
            <TextBlock Classes="label">
                <Run Text="Search roots " /><Run Text="· one per line" Foreground="{DynamicResource FidoTextDim}" />
            </TextBlock>
            <TextBox x:Name="SearchRootsBox" Classes="fido" Text="{Binding SearchRootsText, Mode=TwoWay}"
                     AcceptsReturn="True" Height="96" TextWrapping="NoWrap"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto" />
        </StackPanel>

        <StackPanel Spacing="9">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Classes="label" VerticalAlignment="Center">
                    <Run Text="Editors " /><Run Text="· ● = default (Enter); others open by Ctrl+N" Foreground="{DynamicResource FidoTextDim}" />
                </TextBlock>
                <Button Grid.Column="1" x:Name="AddEditorButton" Classes="secondary" Content="Add" Click="OnAddEditorClick" />
            </Grid>
            <Border BorderBrush="{DynamicResource FidoCardBorder}" BorderThickness="1" CornerRadius="8"
                    Background="{DynamicResource FidoLogBg}">
                <ScrollViewer MaxHeight="232" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="EditorsList" ItemsSource="{Binding Editors}" Margin="12,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:EditorChoice">
                                <Grid RowDefinitions="Auto,Auto" Margin="0,0,0,10"
                                      ColumnDefinitions="Auto,*,Auto,Auto">
                                    <RadioButton Grid.Row="0" Grid.Column="0" GroupName="DefaultEditor"
                                                 IsChecked="{Binding IsDefault, Mode=TwoWay}" VerticalAlignment="Center"
                                                 Margin="0,0,8,0" ToolTip.Tip="Set as default editor" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Classes="fido" Text="{Binding Name, Mode=TwoWay}"
                                             PlaceholderText="name" VerticalAlignment="Center" />
                                    <ComboBox Grid.Row="0" Grid.Column="2" Margin="8,0,0,0" Width="132"
                                              ItemsSource="{Binding KindOptions}" SelectedItem="{Binding Kind, Mode=TwoWay}"
                                              VerticalAlignment="Center" />
                                    <Button Grid.Row="0" Grid.Column="3" Classes="secondary" Margin="8,0,0,0"
                                            Content="✕" Click="OnRemoveEditorClick" ToolTip.Tip="Remove this editor" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Classes="fido" Margin="0,6,0,0"
                                             Text="{Binding Path, Mode=TwoWay}" PlaceholderText="{Binding PathPlaceholder}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <StackPanel Spacing="9">
            <TextBlock Classes="label">
                <Run Text="Worktree root " /><Run Text="· blank = sibling &quot;.worktrees&quot;" Foreground="{DynamicResource FidoTextDim}" />
            </TextBlock>
            <TextBox Classes="fido" Text="{Binding WorktreeRoot, Mode=TwoWay}" PlaceholderText="sibling .worktrees folder" />
        </StackPanel>

        <StackPanel Spacing="9">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Classes="label" VerticalAlignment="Center">
                    <Run Text="New-branch repos " /><Run Text="· tick where an unknown branch may be created" Foreground="{DynamicResource FidoTextDim}" />
                </TextBlock>
                <Button Grid.Column="1" x:Name="DetectReposButton" Classes="secondary" Content="Detect" Click="OnDetectClick" />
            </Grid>
            <Border BorderBrush="{DynamicResource FidoCardBorder}" BorderThickness="1" CornerRadius="8"
                    Background="{DynamicResource FidoLogBg}">
                <ScrollViewer MaxHeight="132" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ReposList" ItemsSource="{Binding NewBranchRepos}" Margin="12,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:RepoChoice">
                                <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}" Content="{Binding DisplayName}"
                                          Foreground="{DynamicResource FidoTextBody}" Margin="0,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <StackPanel Spacing="9">
            <TextBlock Classes="label" Text="Theme" />
            <Border Background="{DynamicResource FidoSegmentTrackBg}" BorderBrush="{DynamicResource FidoSegmentTrackBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="3" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Classes="segment" GroupName="Theme" Content="System"
                                 IsChecked="{Binding IsThemeSystem, Mode=TwoWay}" />
                    <RadioButton Classes="segment" GroupName="Theme" Content="Light"
                                 IsChecked="{Binding IsThemeLight, Mode=TwoWay}" />
                    <RadioButton Classes="segment" GroupName="Theme" Content="Dark"
                                 IsChecked="{Binding IsThemeDark, Mode=TwoWay}" />
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Spacing="9">
            <TextBlock Classes="label">
                <Run Text="Close after opening " /><Run Text="· when Fido quits after launching Rider" Foreground="{DynamicResource FidoTextDim}" />
            </TextBlock>
            <Border Background="{DynamicResource FidoSegmentTrackBg}" BorderBrush="{DynamicResource FidoSegmentTrackBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="3" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Classes="segment" GroupName="CloseAfterOpen" Content="Command line"
                                 IsChecked="{Binding IsCloseCommandLine, Mode=TwoWay}" />
                    <RadioButton Classes="segment" GroupName="CloseAfterOpen" Content="Always"
                                 IsChecked="{Binding IsCloseAlways, Mode=TwoWay}" />
                    <RadioButton Classes="segment" GroupName="CloseAfterOpen" Content="Never"
                                 IsChecked="{Binding IsCloseNever, Mode=TwoWay}" />
                </StackPanel>
            </Border>
            <StackPanel Orientation="Horizontal" Spacing="11" IsEnabled="{Binding IsAutoCloseEnabled}">
                <TextBlock Classes="label" VerticalAlignment="Center">
                    <Run Text="Close delay " /><Run Text="· seconds, 0 = immediately" Foreground="{DynamicResource FidoTextDim}" />
                </TextBlock>
                <TextBox x:Name="CloseDelayBox" Classes="fido" Width="84"
                         Text="{Binding CloseAfterOpenDelayText, Mode=TwoWay}" />
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,4,0,0">
            <Button x:Name="CancelButton" Classes="secondary" Content="Cancel" Click="OnCancelClick" IsCancel="True" />
            <Button x:Name="SaveButton" Classes="primary" Content="Save" Click="OnSaveClick" IsDefault="True" FontSize="13" Padding="24,9" />
        </StackPanel>

    </StackPanel>
</Window>
