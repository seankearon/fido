<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Fido.ViewModels"
        x:Class="Fido.Views.ChooserDialog"
        x:DataType="vm:ChooserViewModel"
        Title="Select"
        Width="660" Height="600"
        MinWidth="480" MinHeight="360"
        WindowDecorations="Full"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/fido-icon-256.png"
        FontFamily="{DynamicResource FidoMono}"
        Background="{DynamicResource FidoWindowBg}">

    <DockPanel Margin="22,20">

        <TextBlock DockPanel.Dock="Top" Text="{Binding Prompt}" Margin="0,0,0,16" TextWrapping="Wrap"
                   FontFamily="{DynamicResource FidoMono}" FontSize="13" Foreground="{DynamicResource FidoDialogPrompt}" />

        <TextBlock DockPanel.Dock="Bottom" Text="Shortcuts: ↑ ↓ = move · Enter / double-click = open · Esc = cancel"
                   Margin="0,12,0,0" Foreground="{DynamicResource FidoTextDim}" FontSize="11" TextWrapping="Wrap" />

        <DockPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
            <!-- Optional destructive action (branch-folder mode): delete the located worktree + branch.
                 Kept on the left, apart from Cancel/Open, so it isn't clicked by reflex; hidden otherwise.
                 IsTabStop=False keeps it out of the tab order so Enter/Space can never fire it by accident —
                 Enter still opens the highlighted item; deleting takes a deliberate mouse click. -->
            <Button x:Name="DeleteButton" DockPanel.Dock="Left" Classes="danger" IsTabStop="False"
                    Content="{Binding DeleteButtonText}" IsVisible="{Binding CanDelete}"
                    Click="OnDeleteClick" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button x:Name="CancelButton" Classes="secondary" Content="Cancel" Click="OnCancelClick" IsCancel="True" />
                <Button x:Name="OkButton" Classes="primary" Content="Open" Click="OnOkClick" IsDefault="True"
                        FontSize="13" Padding="24,9" />
            </StackPanel>
        </DockPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ListBox x:Name="Chooser" Classes="cards"
                     ItemsSource="{Binding Items}"
                     SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                     DoubleTapped="OnListDoubleTapped">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:ChooserItem">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding Title}" FontFamily="{DynamicResource FidoMono}"
                                       FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"
                                       Foreground="{DynamicResource FidoTextPrimary}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Subtitle}" IsVisible="{Binding HasSubtitle}"
                                           FontFamily="{DynamicResource FidoMono}" FontSize="11.5"
                                           VerticalAlignment="Center" Foreground="{DynamicResource FidoTextMuted}" />
                                <HyperlinkButton Content="{Binding CommitShort}" NavigateUri="{Binding CommitUri}"
                                                 IsVisible="{Binding HasCommitLink}" ToolTip.Tip="{Binding CommitUri}"
                                                 FontSize="11.5" Padding="0" MinHeight="0" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding CommitShort}" IsVisible="{Binding HasCommitTextOnly}"
                                           FontFamily="{DynamicResource FidoMono}" FontSize="11.5"
                                           VerticalAlignment="Center" Foreground="{DynamicResource FidoAccentText}" />
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

    </DockPanel>
</Window>
